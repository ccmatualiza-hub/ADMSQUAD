# ── Banco de dados MySQL (em nuvem) ──────────────────────────────────────────
DB_HOST=seu-host-mysql.exemplo.com
DB_PORT=3306
DB_USER=ccm_user
DB_PASSWORD=TROCAR_SENHA_FORTE_AQUI
DB_NAME=ccm_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=TROCAR_POR_STRING_ALEATORIA_64_CHARS
JWT_EXPIRE_HOURS=8

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=3001
FRONTEND_URL=http://localhost:5173
